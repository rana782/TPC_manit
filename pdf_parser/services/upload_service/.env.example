APP_NAME=document-upload-service
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=INFO
STORAGE_ROOT=./data/uploads

JOB_SERVICE_BASE_URL=http://127.0.0.1:8004
ENABLE_JOB_REGISTRATION=true
INTERNAL_SERVICE_TOKEN=change-me-internal-token

EXTRACTION_SERVICE_BASE_URL=http://127.0.0.1:8002
EXTRACTION_INGEST_PATH=/v1/internal/ingest
ENABLE_EXTRACTION_FORWARD=false
EXTRACTION_TIMEOUT_SECONDS=120
FORWARD_RETRIES=3
FORWARD_RETRY_BACKOFF_SECONDS=2
MAX_UPLOAD_BYTES=26214400
