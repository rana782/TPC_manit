APP_NAME=document-extraction-service
HOST=0.0.0.0
PORT=8002
LOG_LEVEL=INFO

NANONETS_API_KEY=
NANONETS_BASE_URL=https://extraction-api.nanonets.com

SYNC_MAX_PDF_PAGES=5
SYNC_MAX_FILE_BYTES=15728640
