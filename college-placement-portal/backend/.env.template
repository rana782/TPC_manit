# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  College Placement Portal — Backend Environment Variables                  ║
# ║  Copy this file to .env and fill in values:  cp .env.template .env         ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─── Core ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database (Supabase PostgreSQL) ────────────────────────────────────────────
# Use Session Pooler URI from Supabase Dashboard -> Project Settings -> Database.
# If your password has special chars like "/" or "#", URL-encode it (%2F, %23).
# Example format:
# postgresql://postgres.<project-ref>:<url-encoded-password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL="postgresql://postgres.your-project-ref:your-url-encoded-password@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require"

# ─── Authentication ───────────────────────────────────────────────────────────
# IMPORTANT: Change this to a strong random string in production (32+ chars)
JWT_SECRET="supersecretjwtkey_change_in_production"

# ─── Google OAuth (Optional — Module 10) ──────────────────────────────────────
# Get credentials from https://console.cloud.google.com/apis/credentials
# In dev mode, mock tokens (mock:email@example.com) work without real credentials
GOOGLE_CLIENT_ID=dummy

# ─── Frontend URL (used in webhook payloads) ──────────────────────────────────
# Vite dev server runs on port 3000 per vite.config.ts
PORT_UI_URL=http://localhost:3000

# ─── ATS Resume Scoring Engine (Module 07) ────────────────────────────────────
# Options: "sbert" (offline keyword matching) or "openai" (embedding-based)
# sbert works without any API keys; openai requires OPENAI_API_KEY
ATS_ENGINE=sbert

# ─── ATS "Analyze Resume" LLM (getATSAnalysis — Resumes page / apply flow) ─────
# OpenAI-compatible Chat Completions (JSON). Default model is gpt-4o-mini on api.openai.com.
# For OpenRouter + Qwen, set ATS_LLM_BASE_URL and ATS_LLM_API_KEY below.
# ATS_LLM_MODEL=qwen/qwen3.6-plus
# ATS_LLM_MODEL_FALLBACKS=qwen/qwen3.6-plus:free,qwen/qwen3-30b-a3b,qwen/qwen3-14b,qwen/qwen3-8b
# OPENAI_ATS_MODEL=gpt-4o-mini

# ─── OpenRouter / Qwen (ATS chat analysis) ────────────────────────────────────
# API keys: https://openrouter.ai/keys — base URL must be the OpenAI-compatible endpoint.
# ATS_LLM_BASE_URL=https://openrouter.ai/api/v1
# ATS_LLM_API_KEY=sk-or-v1-xxxxxxxx
# ATS_LLM_MODEL=qwen/qwen3.6-plus
# ATS_LLM_MODEL_FALLBACKS=qwen/qwen3.6-plus:free,qwen/qwen3-30b-a3b,qwen/qwen3-14b,qwen/qwen3-8b
# Optional: site URL for OpenRouter rankings (defaults to PORT_UI_URL or localhost:3000)
# OPENROUTER_HTTP_REFERER=http://localhost:3000

# ─── OpenAI (optional: legacy; embedding path when ATS_ENGINE=openai; or plain OpenAI for ATS chat)
# Get your key from https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx
# OPENAI_API_BASE_URL=   # only if using a compatible proxy; leave unset for OpenAI

# ─── Zapier Announcements (Optional — Module 08) ──────────────────────────────
# 1. Go to https://zapier.com → Create Zap → Trigger: Webhooks → Catch Hook
# 2. Copy webhook URL below and set ZAPIER_ENABLED=true
ZAPIER_ENABLED=false
ZAPIER_WEBHOOK_URL=

# ─── Zapier LinkedIn Integration (Optional — Module 11) ───────────────────────
# Uses the same ZAPIER_WEBHOOK_URL above. Also toggleable from Admin UI.
ZAPIER_LINKEDIN_ENABLED=false

# ─── WhatsApp Notifications (Optional — Module 09/10) ─────────────────────────
# For local dev, point to the mock server: http://localhost:9001/mock-whatsapp
# Start mock server: node scripts/ui_mock_server.js
# Also toggleable from Admin UI via SystemSetting table.
WHATSAPP_ENABLED=false
WHATSAPP_WEBHOOK_URL=http://localhost:9001/mock-whatsapp

# ─── Generic Notifications (Optional — Module 10) ─────────────────────────────
NOTIFICATIONS_ENABLED=false
WEBHOOK_URL=

# ─── Twilio (Optional — Future SMS Integration, NOT YET IMPLEMENTED) ──────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM_NUMBER=+1234567890

# ─── Brevo SMTP (OTP Emails) ───────────────────────────────────────────────────
# SMTP docs: https://developers.brevo.com/docs/smtp-relay
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_SECURE=false
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
BREVO_SMTP_FROM=
