# College Placement Portal — Backend Environment Variables

# ─── Core ───────────────────────────────────────────────────────────────────
PORT=5001
# Runtime connection (can use Supabase pooler)
# Format: postgresql://postgres.<project-ref>:<url-encoded-password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.your-project-ref:your-url-encoded-password@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require
# Migration connection (must be direct DB host, not pooler)
# Format: postgresql://postgres:<url-encoded-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DIRECT_URL=postgresql://postgres:your-url-encoded-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
JWT_SECRET=your_super_secret_jwt_key_here

# ─── Frontend URL (used in announcement payloads) ───────────────────────────
PORT_UI_URL=http://localhost:5173
# Optional CORS allow-list (comma separated). If omitted, all origins are allowed.
# CORS_ORIGIN=https://your-frontend.vercel.app,http://localhost:3000

# ─── Notification Webhook (generic) ─────────────────────────────────────────
# Set NOTIFICATIONS_ENABLED=true to fire real webhook calls from Module 10
NOTIFICATIONS_ENABLED=false
WEBHOOK_URL=https://hooks.example.com/notify

# ─── Zapier Integration (Module 11 — Announcement Generator) ────────────────
# 1. Sign in to https://zapier.com
# 2. Create a new Zap: Trigger → Webhooks by Zapier → "Catch Hook"
# 3. Copy the generated webhook URL and paste it below
# 4. Set ZAPIER_ENABLED=true to fire real announcements
#
# Sample Zapier webhook URL format:
#   https://hooks.zapier.com/hooks/catch/{zap_id}/{hook_id}/
ZAPIER_ENABLED=false
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/your_zap_id/your_hook_id/

# ─── Company profiles (ratings / reviews / autocomplete) ────────────────────
# Auto-import runs on server start if no CompanyProfile row has source=json_import.
# Put merged-1775126456590.json in college-placement-portal/ (parent of backend/) or backend/data/.
# Push to Supabase: set DATABASE_URL to your pooler URL, then from backend/: npm run import:companies
# COMPANY_DATA_JSON=C:\full\path\to\merged-1775126456590.json
# SKIP_AUTO_COMPANY_IMPORT=true
# Re-run full JSON upsert on every API boot (slow; remove after one deploy): FORCE_COMPANY_JSON_REIMPORT=true

# ─── Persistent baseline seed (Supabase) ────────────────────────────────────
# Safe default:
# - Production: auto-seed is OFF unless AUTO_BASELINE_SEED=true
# - Non-production: auto-seed is ON unless AUTO_BASELINE_SEED=false
# On seed run, if SystemSetting TPC_BASELINE_SEED_VERSION is missing, inserts demo baseline data.
# AUTO_BASELINE_SEED=true    # enable auto baseline seed (recommended only for demo/staging)
# FORCE_BASELINE_SEED=true   # clear marker and re-run once (then remove)
# BASELINE_SEED_PASSWORD=Pass@123   # password for baseline.* test users
# Manual (recommended for controlled setup): from backend/: npm run seed:baseline

# ─── Twilio (optional — future SMS integration) ──────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
# TWILIO_FROM_NUMBER=+1234567890

# ─── Brevo SMTP (OTP Emails) ──────────────────────────────────────────────────
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_SECURE=false
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
BREVO_SMTP_FROM=

# ─── Nanonets document extraction (resume + optional JD file) ────────────────
# Sync API: https://extraction-api.nanonets.com/api/v1/extract/sync
# If unset, ATS uses PDF-parse fallback only (unchanged behavior).
# NANONETS_EXTRACT_URL=https://extraction-api.nanonets.com/api/v1/extract/sync
NANONETS_API_KEY=
# Optional timeout in ms (default 60000)
# NANONETS_EXTRACT_TIMEOUT_MS=60000
# Shorter Nanonets deadline for interactive ATS (fallback to PDF quickly). Default 8000.
# NANONETS_ATS_BUDGET_MS=8000
# Longer budget for upload-time prefetch. Default 45000.
# NANONETS_UPLOAD_BUDGET_MS=45000
# Set to false to silence extraction logs in non-test environments.
# NANONETS_LOG=true
