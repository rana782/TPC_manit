//   PROFILE_LOCKED
//   PROFILE_UNLOCKED
//   CUSTOM
// }

// enum String {
//   PENDING
//   SENT
//   FAILED
// }

model Announcement {
  id              String             @id @default(uuid())
  title           String
  body            String
  audience        String             @default("ALL")  // ALL, STUDENT, SPOC
  createdById     String
  createdBy       User               @relation(fields: [createdById], references: [id], onDelete: Cascade)
  zapierStatus    String @default("")
  zapierResponse  String?
  payload         String
  createdAt       DateTime           @default(now())
  sentAt          DateTime?
}

// enum String {
//   PENDING
//   SENT
//   FAILED
// }

// ---- MODULE 10: NOTIFICATIONS ----

model NotificationTemplate {
  id           String   @id @default(uuid())
  type         String   @unique // e.g., 'APPLICATION_CONFIRMATION', 'OA_SCHEDULED'
  templateText String   
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model NotificationLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String?
  job       Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  message   String   
  channel   String   @default("WHATSAPP")
  status    String   @default("PENDING") // MOCKED, SENT, FAILED
  sentAt    DateTime?
  createdAt DateTime @default(now())
}

model SystemSetting {
  key   String @id
  value String
}

// ---- MODULE 11: LINKEDIN ANNOUNCEMENTS ----

model PlacementAnnouncementLog {
  id             String   @id @default(uuid())
  jobId          String?
  job            Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  companyName    String
  placementYear  Int
  postedByUserId String
  postedBy       User     @relation("AnnouncementLogs", fields: [postedByUserId], references: [id], onDelete: Cascade)
  zapStatus      String   @default("MOCKED") // SUCCESS, FAILED, MOCKED
  responseBody   String?  
  payload        String
  postedAt       DateTime?
  createdAt      DateTime @default(now())
}

// ---- MODULE 12: ALUMNI & ANALYTICS ----

model Alumni {
  id             String   @id @default(uuid())
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  branch         String?
  role           String
  ctc            String?
  placementYear  Int
  linkedinUrl    String?
  companyName    String
  createdAt      DateTime @default(now())
}

/// External job catalog used for company/role recommendations (CSV import).
model JobCatalog {
  id                   String   @id @default(uuid())
  sourceKey            String   @unique
  externalJobId        String?
  company              String
  role                 String
  jobTitle             String?
  skillsText           String?  @db.Text
  skillsArr            String[] @default([])
  jobDescription       String?  @db.Text
  responsibilities     String?  @db.Text
  experienceText       String?
  minExperience        Int?
  maxExperience        Int?
  workType             String?
  location             String?
  country              String?
  salaryRange          String?
  preference           String?
  companySize          Int?
  benefitsText         String?  @db.Text
  companyProfileText   String?  @db.Text
  companySector        String?
  source               String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([company])
  @@index([role])
  @@index([minExperience])
  @@index([maxExperience])
  @@index([companySector])
  @@index([skillsArr], type: Gin)
}
