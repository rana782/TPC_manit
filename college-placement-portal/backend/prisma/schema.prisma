generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String
  role             String     @default("")
  isDisabled       Boolean  @default(false)
  disabledUntil    DateTime?
  
  // SPOC Validation & Permissions
  isVerified       Boolean  @default(false)
  verifiedById     String?
  verifiedBy       User?    @relation("VerifiedSpocs", fields: [verifiedById], references: [id], onDelete: SetNull)
  verifiedAt       DateTime?
  permJobCreate    Boolean  @default(false)
  permLockProfile  Boolean  @default(false)
  permExportCsv    Boolean  @default(false)

  otpHash          String?
  otpExpiry        DateTime?
  googleId         String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relationships
  student          Student?
  postedJobs       Job[]
  notifications    Notification[]
  notificationLogs NotificationLog[]
  announcements    Announcement[]
  lockedProfiles   ProfileLock[]     @relation("LockedBy")
  unlockedProfiles ProfileLock[]     @relation("UnlockedBy")
  placedRecords    PlacementRecord[] @relation("PlacedBySpoc")
  
  verifiedSpocs    User[]            @relation("VerifiedSpocs")
  overridesGiven   ActionOverride[]  @relation("CoordinatorOverrides")
  overridesReceived ActionOverride[] @relation("SpocOverrides")
  announcementLogs PlacementAnnouncementLog[] @relation("AnnouncementLogs")
  alumniRecords    Alumni[]
}

model Student {
  id             String            @id @default(uuid())
  userId         String            @unique
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  branch         String?
  course         String?
  scholarNo      String?           @unique
  phone          String?
  dob            DateTime?
  photoPath      String?           // Path for profile picture upload
  // Academic Stats
  tenthPct       Float?
  tenthYear      Int?
  twelfthPct     Float?
  twelfthYear    Int?
  semester       Int?
  cgpa           Float?
  sgpa           Float?
  backlogs       Int?              @default(0)
  // External Profiles linking
  linkedin       String?
  naukri         String?
  leetcode       String?
  codechef       String?
  codeforces     String?
  // Address block
  address        String?
  city           String?
  state          String?
  pincode        String?

  isLocked       Boolean           @default(false)
  lockedReason   String?
  placementType  String?
  documents      StudentDocument[]
  resumes        Resume[]
  internships    Internship[]
  certifications Certification[]
  applications   JobApplication[]
  placements     PlacementRecord[]
  profileLocks   ProfileLock[]
  alumniRecords  Alumni[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model StudentDocument {
  id          String       @id @default(uuid())
  studentId   String
  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type        String @default("")
  fileName    String
  fileUrl     String
  uploadedAt  DateTime     @default(now())
}

model Resume {
  id           String           @id @default(uuid())
  studentId    String
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  roleName     String?          // The role this resume is tailored for (e.g. SDE, Data Analyst)
  fileName     String
  fileUrl      String
  isActive     Boolean          @default(true) // active for selection when applying
  /// Cached plain text for ATS (Nanonets or PDF fallback) to avoid repeat extraction
  extractedText String?       @db.Text
  /// Structured extraction from Nanonets when available
  extractedJson Json?
  applications JobApplication[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model Internship {
  id          String    @id @default(uuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  company     String
  role        String
  startDate   DateTime
  endDate     DateTime? // Null if current
  description String?   
  certPath    String?
  createdAt   DateTime  @default(now())
}

model Certification {
  id           String   @id @default(uuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title        String
  organization String
  issueDate    DateTime
  certPath     String?
  createdAt    DateTime @default(now())
}

// enum String {
//   COLLEGE_ID
//   AADHAAR
//   PAN
//   OTHER
// }

model JobApplication {
  id                 String            @id @default(uuid())
  studentId          String
  student            Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  jobId              String
  job                Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resumeId           String
  resume             Resume            @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  applicationData    String              // Point in time snapshot
  extraAnswers       String?             @default("{}") // Custom questions
  status             String @default("")
  currentStageIndex  Int               @default(0)
  atsScore           Float?            // 0-100 ATS compatibility score
  atsExplanation     String?           // Human-readable summary of match
  atsMatchedKeywords String?             // Array of matched keyword strings
  semanticScore      Float?            @default(0)
  skillScore         Float?            @default(0)
  skillsMatched      String?           @default("[]")
  skillsMissing      String?           @default("[]")
  suggestions        String?           @default("[]")
  appliedAt          DateTime          @default(now())
}

model Job {
  id                    String           @id @default(uuid())
  role                  String
  companyName           String
  description           String
  jobType               String           @default("Full-Time")
  ctc                   String?
  jdPath                String?
  jnfPath               String?
  eligibleBranches      String             @default("[]") // String array of branch codes
  cgpaMin               Float            @default(0)
  requiredProfileFields String             @default("[]") // e.g. ["resume", "cgpa", "tenthPct"]
  customQuestions       String             @default("[]") // e.g. [{ label: "Why us?", type: "text", required: true }]
  blockPlaced           Boolean          @default(true)
  status                String        @default("")
  postedById            String
  postedBy              User             @relation(fields: [postedById], references: [id], onDelete: Cascade)
  applicationDeadline   DateTime
  placementMode         String    @default("")
  applications          JobApplication[]
  stages                JobStage[]
  placements            PlacementRecord[]
  notificationLogs      NotificationLog[]
  announcementLogs      PlacementAnnouncementLog[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
}

// enum String {
//   DRAFT
//   PUBLISHED
//   CLOSED
// }

model JobStage {
  id            String      @id @default(uuid())
  jobId         String
  job           Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name          String      // e.g., "Online Assessment", "Technical Interview 1", "HR Round"
  scheduledDate DateTime
  status        String @default("")
  shortlistDocPath String?
  /// Optional label for the pipeline shortlist PDF (shown in links)
  shortlistDocTitle String?
  /// Optional comments / instructions for this stage (shown in Job Timeline)
  notes         String?
  /// Optional PDF or image uploaded when the stage was created
  attachmentPath String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// enum String {
//   PENDING
//   COMPLETED
// }

model PlacementRecord {
  id              String         @id @default(uuid())
  studentId       String
  student         Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  jobId           String?
  job             Job?           @relation(fields: [jobId], references: [id], onDelete: SetNull)
  companyName     String
  role            String
  ctc             String?
  placementMode   String  @default("")
  createdBySpocId String?
  createdBySpoc   User?          @relation("PlacedBySpoc", fields: [createdBySpocId], references: [id], onDelete: SetNull)
  placedAt        DateTime       @default(now())
}

model ProfileLock {
  id              String      @id @default(uuid())
  studentId       String
  student         Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  profileLocked   Boolean     @default(true)
  lockedById      String
  lockedBy        User        @relation("LockedBy", fields: [lockedById], references: [id], onDelete: Cascade)
  lockedAt        DateTime    @default(now())
  reason          String?     
  isActive        Boolean     @default(true)
  unlockedById    String?
  unlockedBy      User?       @relation("UnlockedBy", fields: [unlockedById], references: [id], onDelete: SetNull)
  unlockedAt      DateTime?
}

model ActionOverride {
  id               String   @id @default(uuid())
  coordinatorId    String
  coordinator      User     @relation("CoordinatorOverrides", fields: [coordinatorId], references: [id], onDelete: Cascade)
  spocId           String
  spoc             User     @relation("SpocOverrides", fields: [spocId], references: [id], onDelete: Cascade)
  actionType       String   // e.g. "UNLOCK_STUDENT", "DELETE_JOB"
  entity           String   // e.g. "ProfileLock", "Job"
  entityId         String
  originalValue    String?
  overriddenValue  String?
  reason           String?
  createdAt        DateTime @default(now())
}

