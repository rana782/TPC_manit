{
  "name": "placement-backend",
  "version": "1.0.0",
  "main": "src/server.ts",
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "db:deploy": "prisma migrate deploy",
    "start:prod": "npm run db:deploy && node dist/src/server.js",
    "test": "jest",
    "migrate": "prisma migrate dev",
    "seed": "prisma db seed",
    "db:seed": "prisma db seed",
    "seed:company-profiles": "ts-node scripts/importCompanies.ts",
    "import:companies": "ts-node scripts/importCompanies.ts",
    "seed:test-random": "ts-node scripts/seed_test_random.ts",
    "seed:coordinator": "ts-node scripts/seed_coordinator.ts",
    "migrate:local-to-supabase": "ts-node scripts/migrate_local_to_supabase.ts",
    "seed:permanent-demo": "ts-node scripts/runPermanentDemoSeed.ts",
    "seed:bulk-mock": "ts-node scripts/seed_bulk_mock.ts",
    "seed:bulk-mock:clean": "ts-node scripts/seed_bulk_mock.ts --clean",
    "seed:api-coverage": "ts-node scripts/seed_api_coverage.ts",
    "seed:baseline": "ts-node scripts/seed_baseline.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@types/json2csv": "^5.0.7",
    "@types/pdf-parse": "^1.1.5",
    "axios": "^1.13.6",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^10.6.1",
    "helmet": "^7.0.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "openai": "^6.27.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "winston": "^3.10.0",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.14",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.4",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.5.9",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "prisma": "^5.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
