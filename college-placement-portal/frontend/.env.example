# Backend origin without /api (must match backend PORT, default 5001 in this repo).
# Local dev: http://127.0.0.1:5001 — or leave empty to use Vite /api proxy (then set VITE_PROXY_BACKEND_PORT).
# Production build: set to your public API origin, e.g. https://api.yourdomain.com (same host you set CORS_ORIGIN for on the backend).
VITE_API_URL=http://127.0.0.1:5001
# When using the dev proxy for /api, must match backend listen port.
VITE_PROXY_BACKEND_PORT=5001
