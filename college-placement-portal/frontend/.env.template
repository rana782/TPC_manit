# ─── Backend API URL ──────────────────────────────────────────────────────────
# Local dev: leave VITE_API_URL empty to use the Vite /api proxy to VITE_PROXY_BACKEND_PORT (default 5001), same as backend PORT.
# Or set explicitly, e.g. http://127.0.0.1:5001
VITE_API_URL=
VITE_PROXY_BACKEND_PORT=5001
